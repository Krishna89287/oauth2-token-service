{
  "name": "oauth2-token-service",
  "version": "0.1.0",
  "description": "OAuth2 authorization server: client credentials, authorization code with PKCE, and refresh token rotation with reuse detection.",
  "license": "MIT",
  "author": "Krishna Gove <krishnagove88@gmail.com>",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-migrations.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/migrate.ts --seed",
    "demo": "tsx scripts/demo.ts",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests scripts --ext .ts"
  },
  "dependencies": {
    "@fastify/formbody": "^7.4.0",
    "fastify": "^4.28.1",
    "jose": "^5.6.3",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
